# ===========================================
# 非秘匿情報のみ .env.local に記載する
# 秘匿情報はシェル環境変数または Vercel 環境変数で管理
# ===========================================

# App URL (非秘匿)
NEXTAUTH_URL=http://localhost:3000

# Database (非秘匿 — ローカルは SQLite)
DATABASE_URL=file:./prisma/dev.db

# -------------------------------------------
# 以下は .env.local に書かないこと
# シェルで export するか、Vercel 環境変数に設定する
# -------------------------------------------
# NEXTAUTH_SECRET=<ランダム文字列>
# ROBLOX_CLIENT_ID=<Roblox OAuth App Client ID>
# ROBLOX_CLIENT_SECRET=<Roblox OAuth App Client Secret>
# ENCRYPTION_KEY=<32バイトhex (64文字)>
